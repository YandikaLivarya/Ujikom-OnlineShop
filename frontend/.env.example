# Backend API URL Configuration
# Copy this file to .env dan sesuaikan dengan environment Anda

# Development dengan Ngrok (untuk webhook testing):
VITE_API_URL=https://xxxx-xxx-xxx-xxx.ngrok.io

# Development dengan Localhost:
# VITE_API_URL=http://localhost:5000

# Production:
# VITE_API_URL=https://api.yourdomain.com
